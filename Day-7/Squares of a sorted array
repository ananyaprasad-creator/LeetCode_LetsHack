class Solution(object):
    def findMissingAndRepeatedValues(self, grid):
        """
        :type grid: List[List[int]]
        :rtype: List[int]
        """
        n = len(grid)
        total_numbers = n * n
        seen = set()
        a = -1
    
        for row in grid:
            for num in row:
                if num in seen:
                    a = num
                seen.add(num)
     
        b = -1
        for i in range(1, total_numbers + 1):
            if i not in seen:
                b = i
                break
                
        return [a, b]
